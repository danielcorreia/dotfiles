#!/usr/bin/env bash

# Bootstrap my macbook

brew=$(which brew)
if [ -z $brew ]; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # add brew to $PATH
  echo >> /Users/$(whoami)/.zprofile
  echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >>  /Users/$(whoami)/.zprofile
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi;

ansible_playbook=$(which ansible-playbook)
if [ -z $ansible_playbook ]; then
  brew install ansible
fi;

# Load saved config if it exists (skips prompts on subsequent runs)
CONFIG_FILE="$HOME/.config/dotfiles.conf"
if [ -f "$CONFIG_FILE" ]; then
  source "$CONFIG_FILE"
fi

# Build extra vars — only pass non-empty values so vars_prompt still fires for missing ones
extra_vars=()

email="${DOTFILES_EMAIL:-}"
[ -n "$email" ] && extra_vars+=("-e" "email=$email")

setup_system="${DOTFILES_SETUP_SYSTEM:-}"
[ -n "$setup_system" ] && extra_vars+=("-e" "setup_system=$setup_system")

setup_macos="${DOTFILES_SETUP_MACOS:-}"
[ -n "$setup_macos" ] && extra_vars+=("-e" "setup_macos=$setup_macos")

setup_git="${DOTFILES_SETUP_GIT:-}"
[ -n "$setup_git" ] && extra_vars+=("-e" "setup_git=$setup_git")

setup_ohmyzsh="${DOTFILES_SETUP_OHMYZSH:-}"
[ -n "$setup_ohmyzsh" ] && extra_vars+=("-e" "setup_ohmyzsh=$setup_ohmyzsh")

setup_node="${DOTFILES_SETUP_NODE:-}"
[ -n "$setup_node" ] && extra_vars+=("-e" "setup_node=$setup_node")

ansible-playbook main.yml "${extra_vars[@]}"
